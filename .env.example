NODE_ENV=production
PORT=3000
CORS_ORIGIN=https://girafadesigner.github.io,http://localhost:3000

# Obrigatorio
JWT_SECRET=troque-por-um-segredo-forte

# SMTP (recuperacao de senha por email) - opcional no boot, necessario para envio real
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu-email@dominio.com
SMTP_PASS=sua-senha-app
SMTP_FROM=seu-email@dominio.com

# SQLCipher (recomendado em producao; sem SQLCipher o app sobe sem criptografia)
DB_KEY=troque-por-uma-chave-forte

# Seed admin inicial (se nao informar senha, o admin nao e criado automaticamente)
ADMIN_SEED_USERNAME=admin@seu-dominio.com
ADMIN_SEED_PASSWORD=troque-por-uma-senha-forte

# Somente para testes locais (NUNCA em producao)
ENABLE_MOCK_NOTIFICATIONS=false

# Limites de seguranca
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10
MAX_UPLOAD_FILE_SIZE=2097152

# Checkout de atendimento
WHATSAPP_NUMBER=5511999999999
